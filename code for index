	function makeToggle(id, key, onFn, offFn) {
		document.getElementById(id).onclick = function() {
			this.classList.toggle('active');
			settings[key] = this.classList.contains('active');
			localStorage.setItem(key, settings[key]);
			settings[key] ? onFn && onFn() : offFn && offFn();
		};
	}

	makeToggle('animation-toggle','animations',
		() => document.body.classList.remove('hover-off'),
		() => document.body.classList.add('hover-off'));
	makeToggle('glow-toggle','glow',
		() => document.body.classList.add('glow-on'),
		() => document.body.classList.remove('glow-on'));
	makeToggle('shadow-toggle','shadow');
	makeToggle('autoload-toggle','autoload');
	makeToggle('playcount-toggle','playcount');
	makeToggle('hover-effect','hoverEffect',
		() => document.body.classList.remove('hover-off'),
		() => document.body.classList.add('hover-off'));
	makeToggle('smooth-scroll','smoothScroll',
		() => document.documentElement.style.scrollBehavior = 'smooth',
		() => document.documentElement.style.scrollBehavior = 'auto');

	document.getElementById('brightness-slider').addEventListener('input', e => applyBrightness(e.target.value));

	document.querySelectorAll('.bg-option').forEach(opt => {
		opt.onclick = () => applyEffect(opt.dataset.bg);
	});

	document.querySelectorAll('.color-swatch').forEach(s => {
		s.onclick = () => applyColor(s.dataset.rgb);
	});

	document.getElementById('custom-color').addEventListener('input', e => {
		const rgb = hexToRgb(e.target.value);
		document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
		settings.bgColor = rgb;
		localStorage.setItem('bgColor', rgb);
		document.documentElement.style.setProperty('--bg-color', rgb);
		rainRGB = rgb.split(',').map(Number);
	});

	document.getElementById('grid-size').onchange = function() {
		settings.gridSize = this.value;
		localStorage.setItem('gridSize', this.value);
		updateGridSize();
	};

	document.getElementById('clear-favorites').onclick = () => {
		if (confirm('Clear all favorites?')) {
			favorites.clear(); localStorage.setItem('favorites','[]'); renderGames();
		}
	};

	document.getElementById('reset-settings').onclick = () => {
		if (confirm('Reset all settings to defaults?')) { localStorage.clear(); location.reload(); }
	};

	document.getElementById('info-btn').onclick = () => {
		document.getElementById('info-textarea').value = localStorage.getItem('notes') || '';
		document.getElementById('info-modal').classList.add('on');
	};
	document.getElementById('save-info').onclick = () => {
		localStorage.setItem('notes', document.getElementById('info-textarea').value);
		alert('Notes saved!');
	};
	document.getElementById('close-info').onclick = () =>
		document.getElementById('info-modal').classList.remove('on');

	// ── BOOT ──
	loadSettings();
	renderGames();
	</script>
</body>
</html>
