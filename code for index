<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>MathLine</title>
	<link rel="icon" type="image/svg+xml"
		href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='50' fill='%23E31717'/%3E%3Ccircle cx='50' cy='50' r='33' fill='none' stroke='%23FFF' stroke-width='3'/%3E%3C/svg%3E" />
	<style>
		:root {
			--accent: #fff;
			--text: #fff;
			--nav: #0f1419;
			--nav-w: 0px;
			--top: #0a0e14;
			--top-h: 56px;
			--bg: #0d1117;
			--card-bg: #161b22;
			--card-hover: #1c2128;
			--theme: 'dark';
			--bg-style: 'stars';
		}

		*,
		*::before,
		*::after {
			box-sizing: border-box;
			margin: 0;
			padding: 0;
		}

		html,
		body {
			height: 100%;
			font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial;
			color: var(--text);
			background: var(--bg);
			overflow: hidden;
		}

		body::before {
			content: '';
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			pointer-events: none;
			z-index: 1;
			background-image:
				radial-gradient(2px 2px at 20px 30px, rgba(255, 255, 255, 0.5), rgba(0, 0, 0, 0)),
				radial-gradient(2px 2px at 60px 70px, rgba(255, 255, 255, 0.5), rgba(0, 0, 0, 0)),
				radial-gradient(1px 1px at 50px 50px, rgba(255, 255, 255, 0.8), rgba(0, 0, 0, 0)),
				radial-gradient(1px 1px at 130px 80px, rgba(255, 255, 255, 0.8), rgba(0, 0, 0, 0)),
				radial-gradient(2px 2px at 90px 10px, rgba(255, 255, 255, 0.5), rgba(0, 0, 0, 0));
			background-repeat: repeat;
			background-size: 200px 200px;
			animation: twinkle 5s ease-in-out infinite;
		}

		body.bg-none::before {
			display: none;
		}

		body.bg-rain::before {
			background-image:
				linear-gradient(90deg, transparent 24%, rgba(255, 255, 255, .05) 25%, rgba(255, 255, 255, .05) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .05) 75%, rgba(255, 255, 255, .05) 76%, transparent 77%, transparent),
				linear-gradient(rgba(255, 255, 255, .03) 1px, transparent 1px);
			background-size: 50px 50px;
			animation: rain 0.3s linear infinite;
		}

		body.bg-grid::before {
			background-image:
				linear-gradient(0deg, transparent 24%, rgba(255, 255, 255, .05) 25%, rgba(255, 255, 255, .05) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .05) 75%, rgba(255, 255, 255, .05) 76%, transparent 77%, transparent 100%),
				linear-gradient(90deg, transparent 24%, rgba(255, 255, 255, .05) 25%, rgba(255, 255, 255, .05) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .05) 75%, rgba(255, 255, 255, .05) 76%, transparent 77%, transparent 100%);
			background-size: 50px 50px;
			animation: none;
		}

		body.bg-dots::before {
			background-image: radial-gradient(circle, rgba(255, 255, 255, 0.4) 1px, transparent 1px);
			background-size: 20px 20px;
			animation: none;
		}

		body.bg-lines::before {
			background-image: repeating-linear-gradient(0deg,
					transparent,
					transparent 49px,
					rgba(255, 255, 255, 0.1) 49px,
					rgba(255, 255, 255, 0.1) 50px);
			animation: none;
		}

		body.bg-waves::before {
			background: linear-gradient(45deg, transparent 30%, rgba(255, 255, 255, 0.05) 50%, transparent 70%);
			background-size: 100px 100px;
			animation: wave 2s linear infinite;
		}

		body.bg-nebula::before {
			background:
				radial-gradient(ellipse at 20% 50%, rgba(255, 100, 255, 0.1) 0%, transparent 50%),
				radial-gradient(ellipse at 80% 50%, rgba(100, 100, 255, 0.1) 0%, transparent 50%),
				radial-gradient(ellipse at 50% 0%, rgba(100, 255, 200, 0.05) 0%, transparent 50%);
			animation: nebula 8s ease-in-out infinite;
		}

		@keyframes twinkle {

			0%,
			100% {
				opacity: 0.3;
			}

			50% {
				opacity: 0.8;
			}
		}

		@keyframes rain {
			0% {
				transform: translateY(-100%);
			}

			100% {
				transform: translateY(100vh);
			}
		}

		@keyframes wave {
			0% {
				transform: translateX(0);
			}

			100% {
				transform: translateX(100px);
			}
		}

		@keyframes nebula {

			0%,
			100% {
				opacity: 0.3;
			}

			50% {
				opacity: 0.6;
			}
		}

		#topbar {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			height: var(--top-h);
			background: var(--top);
			z-index: 30;
			display: flex;
			align-items: center;
			gap: 14px;
			padding: 0 16px;
			border-bottom: 1px solid rgba(255, 255, 255, .1);
			box-shadow: 0 2px 4px rgba(0, 0, 0, .3);
		}

		#logo {
			font-size: 1.3rem;
			font-weight: 800;
			color: #fff;
			text-shadow: 0 0 10px rgba(255, 255, 255, .3);
			white-space: nowrap;
			letter-spacing: -.5px;
		}

		#search {
			flex: 1;
			max-width: 480px;
			background: rgba(255, 255, 255, .05);
			color: var(--text);
			padding: 8px 14px;
			font-size: 14px;
			border-radius: 20px;
			border: 1px solid rgba(255, 255, 255, .1);
			outline: none;
			transition: border-color .2s, background .2s;
		}

		#search:focus {
			border-color: rgba(255, 255, 255, .3);
			background: rgba(255, 255, 255, .1);
		}

		#search::placeholder {
			color: rgba(255, 255, 255, .35);
		}

		#top-right {
			margin-left: auto;
			display: flex;
			align-items: center;
			gap: 10px;
		}

		#settings-btn {
			width: 36px;
			height: 36px;
			border-radius: 50%;
			border: none;
			background: rgba(255, 255, 255, .08);
			color: #fff;
			font-size: 18px;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: background .2s;
		}

		#settings-btn:hover {
			background: rgba(255, 255, 255, .15);
		}

		#info-btn {
			width: 36px;
			height: 36px;
			border-radius: 50%;
			border: none;
			background: rgba(255, 255, 255, .08);
			color: #fff;
			font-size: 18px;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: background .2s;
		}

		#info-btn:hover {
			background: rgba(255, 255, 255, .15);
		}

		#nav {
			display: none;
		}

		#main {
			position: fixed;
			top: var(--top-h);
			left: 0;
			right: 0;
			bottom: 0;
			overflow-y: auto;
			background: transparent;
			scrollbar-width: thin;
			scrollbar-color: rgba(255, 255, 255, .15) transparent;
			z-index: 2;
		}

		#content {
			padding: 20px 20px 40px;
		}

		.section-header {
			display: flex;
			align-items: center;
			gap: 8px;
			margin-bottom: 14px;
			margin-top: 24px;
		}

		.section-header:first-child {
			margin-top: 0;
		}

		.section-title {
			font-size: 1rem;
			font-weight: 700;
			color: #fff;
		}

		.section-count {
			font-size: 12px;
			color: rgba(255, 255, 255, .4);
			font-weight: 400;
		}

		#game-list {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
			gap: 12px;
		}

		.card {
			background: var(--card-bg);
			border-radius: 10px;
			cursor: pointer;
			overflow: hidden;
			border: 1px solid rgba(255, 255, 255, .1);
			transition: transform .2s, border-color .2s, background .2s, box-shadow .2s;
			position: relative;
		}

		.card:hover {
			transform: translateY(-3px) scale(1.02);
			border-color: rgba(255, 255, 255, .2);
			background: var(--card-hover);
			box-shadow: 0 4px 12px rgba(255, 255, 255, .1);
		}

		.card-thumb {
			width: 100%;
			aspect-ratio: 16/9;
			position: relative;
			overflow: hidden;
			background: linear-gradient(135deg, #1c2128, #0d1117);
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.card-thumb-grad {
			width: 100%;
			height: 100%;
			position: absolute;
			inset: 0;
		}

		.card-initials {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.8rem;
			font-weight: 800;
			letter-spacing: -.02em;
			color: rgba(255, 255, 255, .15);
			text-shadow: 0 2px 8px rgba(0, 0, 0, .5);
			user-select: none;
		}

		.card-info {
			padding: 8px 10px 10px;
		}

		.card-name {
			font-size: 13px;
			font-weight: 600;
			color: rgba(255, 255, 255, .95);
			line-height: 1.3;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.card-fav {
			position: absolute;
			top: 6px;
			right: 6px;
			background: rgba(0, 0, 0, .6);
			border: none;
			cursor: pointer;
			width: 28px;
			height: 28px;
			border-radius: 50%;
			font-size: 14px;
			color: rgba(255, 255, 255, .5);
			display: flex;
			align-items: center;
			justify-content: center;
			opacity: 0;
			transition: opacity .15s, color .15s;
			z-index: 2;
			box-shadow: 0 2px 4px rgba(0, 0, 0, .3);
		}

		.card:hover .card-fav {
			opacity: 1;
		}

		.card-faon {
			opacity: 1;
			color: #ffd700;
		}

		.card-fav:hover {
			color: #ffd700;
		}

		.card.req {
			border: 2px dashed rgba(255, 165, 0, .5);
		}

		.card.req .card-name {
			color: #ffa500;
		}

		body.glow-on .card:hover {
			box-shadow: 0 0 18px rgba(255, 255, 255, .3);
		}

		body.hover-off .card:hover {
			transform: none !important;
		}

		#overlay {
			display: none;
			position: fixed;
			inset: 0;
			z-index: 50;
			background: #000;
			flex-direction: column;
		}

		#overlay.on {
			display: flex;
		}

		#gframe {
			flex: 1;
			width: 100%;
			border: none;
			background: #000;
		}

		#gload {
			position: absolute;
			inset: 0;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			background: #000;
			z-index: 2;
		}

		#gload.hide {
			display: none;
		}

		.spin {
			border: 4px solid rgba(255, 255, 255, .2);
			border-top: 4px solid #fff;
			border-radius: 50%;
			width: 40px;
			height: 40px;
			animation: spin 1s linear infinite;
			margin-bottom: 18px;
		}

		@keyframes spin {
			to {
				transform: rotate(360deg);
			}
		}

		#bar-wrap {
			width: 260px;
			height: 8px;
			background: rgba(255, 255, 255, .15);
			border-radius: 99px;
			overflow: hidden;
			margin-top: 14px;
		}

		#bar {
			height: 100%;
			width: 0;
			background: #fff;
			border-radius: 99px;
			box-shadow: 0 0 8px rgba(255, 255, 255, .5);
		}

		#bar-lbl {
			margin-top: 10px;
			font-size: 13px;
			color: rgba(255, 255, 255, .5);
		}

		#fs-btn {
			position: fixed;
			right: 18px;
			top: 18px;
			padding: 8px 14px;
			border-radius: 8px;
			border: none;
			cursor: pointer;
			z-index: 60;
			font-weight: 700;
			background: #fff;
			color: #000;
		}

		#bk-btn {
			position: fixed;
			left: 18px;
			top: 18px;
			padding: 8px 14px;
			border-radius: 8px;
			border: none;
			cursor: pointer;
			z-index: 60;
			font-weight: 700;
			background: rgba(0, 0, 0, .55);
			color: #fff;
		}

		#browser-page {
			display: none;
			position: fixed;
			inset: 0;
			z-index: 10;
			top: var(--top-h);
		}

		#browser-page.on {
			display: flex;
			flex-direction: column;
		}

		#browser-page iframe {
			width: 100%;
			height: 100%;
			border: none;
		}

		.modal {
			display: none;
			position: fixed;
			z-index: 55;
			inset: 0;
			background: rgba(0, 0, 0, .75);
			backdrop-filter: blur(6px);
		}

		.modal.on {
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.modal-box {
			background: #0d1117;
			padding: 28px;
			border-radius: 14px;
			max-width: 460px;
			width: 90%;
			color: var(--text);
			border: 1px solid rgba(255, 255, 255, .1);
			max-height: 80vh;
			overflow-y: auto;
			box-shadow: 0 10px 40px rgba(0, 0, 0, .5);
		}

		.modal-thumb {
			width: 100%;
			aspect-ratio: 16/9;
			border-radius: 8px;
			overflow: hidden;
			margin-bottom: 18px;
			position: relative;
			background: linear-gradient(135deg, #1c2128, #0d1117);
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.modal-thumb-grad {
			width: 100%;
			height: 100%;
		}

		.modal-thumb-title {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 2.5rem;
			font-weight: 800;
			color: rgba(255, 255, 255, .15);
			letter-spacing: -.02em;
		}

		.mtrow {
			display: flex;
			align-items: center;
			gap: 10px;
			margin-bottom: 14px;
		}

		.mtrow h2 {
			flex: 1;
			font-size: 1.2rem;
			color: #fff;
		}

		.mfav {
			font-size: 22px;
			background: none;
			border: none;
			cursor: pointer;
			color: rgba(255, 255, 255, .3);
			transition: color .2s;
			padding: 4px;
		}

		.mfav:hover,
		.mfaon {
			color: #ffd700;
		}

		.mstat {
			display: flex;
			justify-content: space-between;
			padding: 8px 0;
			border-bottom: 1px solid rgba(255, 255, 255, .1);
			font-size: 14px;
		}

		.mstat:last-of-type {
			border: none;
		}

		.mstat b {
			color: rgba(255, 255, 255, .5);
			font-weight: 600;
		}

		.mbtns {
			display: flex;
			gap: 10px;
			margin-top: 18px;
			justify-content: center;
		}

		.mbtns button {
			padding: 10px 22px;
			border: none;
			border-radius: 8px;
			cursor: pointer;
			font-weight: 700;
			font-size: 14px;
		}

		.mbplay {
			background: #fff;
			color: #000;
		}

		.mbplay:hover {
			filter: brightness(0.9);
		}

		.mbclose {
			background: rgba(255, 255, 255, .1);
			color: var(--text);
			border: 1px solid rgba(255, 255, 255, .2);
		}

		.mbclose:hover {
			background: rgba(255, 255, 255, .18);
		}

		/* Settings Drawer - RIGHT SIDE */
		#settings-drawer {
			position: fixed;
			right: -420px;
			top: 0;
			bottom: 0;
			width: 400px;
			background: #0a0e14;
			z-index: 100;
			transition: right .3s;
			overflow: hidden;
			border-left: 1px solid rgba(255, 255, 255, .1);
			box-shadow: -2px 0 30px rgba(0, 0, 0, .5);
			display: flex;
			flex-direction: column;
		}

		#settings-drawer.open {
			right: 0;
		}

		.settings-header {
			padding: 18px 20px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			border-bottom: 1px solid rgba(255, 255, 255, .1);
			flex-shrink: 0;
		}

		.settings-header h2 {
			color: #fff;
			font-size: 1.2rem;
		}

		.settings-close-btn {
			background: none;
			border: none;
			color: rgba(255, 255, 255, .4);
			font-size: 22px;
			cursor: pointer;
			padding: 4px;
			transition: color .2s;
		}

		.settings-close-btn:hover {
			color: #fff;
		}

		.settings-tabs {
			display: flex;
			gap: 0;
			border-bottom: 1px solid rgba(255, 255, 255, .1);
			padding: 0;
			flex-shrink: 0;
		}

		.settings-tab {
			flex: 1;
			padding: 12px 10px;
			border: none;
			background: rgba(255, 255, 255, .05);
			color: rgba(255, 255, 255, .5);
			cursor: pointer;
			font-size: 12px;
			font-weight: 600;
			transition: all .2s;
			border-bottom: 2px solid transparent;
		}

		.settings-tab:hover {
			background: rgba(255, 255, 255, .1);
		}

		.settings-tab.active {
			background: rgba(255, 255, 255, .08);
			color: #fff;
			border-bottom-color: #fff;
		}

		.settings-content {
			flex: 1;
			overflow-y: auto;
			scrollbar-width: thin;
			scrollbar-color: rgba(255, 255, 255, .1) transparent;
		}

		.settings-panel {
			display: none;
			padding: 16px 18px;
		}

		.settings-panel.active {
			display: block;
		}

		.settings-group {
			margin-bottom: 20px;
		}

		.settings-group-title {
			display: block;
			color: rgba(255, 255, 255, .45);
			font-weight: 700;
			font-size: 11px;
			letter-spacing: .06em;
			text-transform: uppercase;
			margin-bottom: 12px;
		}

		.settings-option {
			margin-bottom: 14px;
		}

		.settings-option label {
			display: flex;
			align-items: center;
			gap: 8px;
			cursor: pointer;
			font-size: 14px;
			color: rgba(255, 255, 255, .8);
		}

		.settings-toggle {
			width: 40px;
			height: 22px;
			background: rgba(255, 255, 255, .1);
			border: none;
			border-radius: 12px;
			cursor: pointer;
			position: relative;
			transition: background .2s;
			margin-left: auto;
			flex-shrink: 0;
		}

		.settings-toggle::after {
			content: '';
			position: absolute;
			width: 18px;
			height: 18px;
			background: #fff;
			border-radius: 50%;
			top: 2px;
			left: 2px;
			transition: left .2s;
		}

		.settings-toggle.active {
			background: rgba(255, 255, 255, .3);
		}

		.settings-toggle.active::after {
			left: 20px;
		}

		.settings-buttons {
			display: flex;
			flex-direction: column;
			gap: 8px;
		}

		.settings-btn {
			padding: 10px;
			border: none;
			border-radius: 8px;
			background: rgba(255, 255, 255, .1);
			color: #fff;
			cursor: pointer;
			font-weight: 600;
			font-size: 13px;
			text-align: center;
			transition: background .2s;
			border: 1px solid rgba(255, 255, 255, .2);
		}

		.settings-btn:hover {
			background: rgba(255, 255, 255, .18);
		}

		.settings-description {
			font-size: 12px;
			color: rgba(255, 255, 255, .35);
			margin-top: 6px;
			line-height: 1.4;
		}

		.bg-grid-options {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 10px;
		}

		.bg-option {
			padding: 12px;
			border: 2px solid rgba(255, 255, 255, .15);
			border-radius: 8px;
			background: rgba(255, 255, 255, .05);
			color: #fff;
			cursor: pointer;
			font-size: 12px;
			font-weight: 600;
			text-align: center;
			transition: all .2s;
		}

		.bg-option:hover {
			border-color: rgba(255, 255, 255, .3);
			background: rgba(255, 255, 255, .1);
		}

