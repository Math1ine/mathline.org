<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>MathLine</title>
	<link rel="icon" type="image/svg+xml"
		href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='50' fill='%23E31717'/%3E%3Ccircle cx='50' cy='50' r='33' fill='none' stroke='%23FFF' stroke-width='3'/%3E%3C/svg%3E" />
	<style>
		:root {
			--text: #fff;
			--top: #0a0e14;
			--top-h: 56px;
			--bg: #0d1117;
			--card-bg: rgba(22, 27, 34, 0.45);
			--card-hover: rgba(28, 33, 40, 0.65);
			--bg-brightness: 0.7;
			--bg-color: 255,255,255;
		}

		*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

		html, body {
			height: 100%;
			font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial;
			color: var(--text);
			background: var(--bg);
			overflow: hidden;
		}

		#bg-canvas {
			position: fixed; top: 0; left: 0;
			width: 100%; height: 100%;
			pointer-events: none; z-index: 1; display: none;
		}

		#bg-layer {
			position: fixed; top: 0; left: 0;
			width: 100%; height: 100%;
			pointer-events: none; z-index: 1;
			opacity: var(--bg-brightness);
		}

		#bg-layer.stars {
			background-image:
				radial-gradient(2px 2px at 15px 25px,  rgba(var(--bg-color),0.9), transparent),
				radial-gradient(1px 1px at 55px 65px,  rgba(var(--bg-color),0.7), transparent),
				radial-gradient(2px 2px at 90px 15px,  rgba(var(--bg-color),0.8), transparent),
				radial-gradient(1px 1px at 130px 80px, rgba(var(--bg-color),0.6), transparent),
				radial-gradient(2px 2px at 170px 40px, rgba(var(--bg-color),0.9), transparent),
				radial-gradient(1px 1px at 45px 110px, rgba(var(--bg-color),0.5), transparent),
				radial-gradient(2px 2px at 195px 95px, rgba(var(--bg-color),0.7), transparent),
				radial-gradient(1px 1px at 75px 140px, rgba(var(--bg-color),0.8), transparent),
				radial-gradient(2px 2px at 155px 155px,rgba(var(--bg-color),0.6), transparent),
				radial-gradient(1px 1px at 20px 170px, rgba(var(--bg-color),0.9), transparent);
			background-size: 200px 200px;
			animation: twinkle 4s ease-in-out infinite;
		}

		#bg-layer.grid {
			background-image:
				linear-gradient(rgba(var(--bg-color),.2) 1px, transparent 1px),
				linear-gradient(90deg, rgba(var(--bg-color),.2) 1px, transparent 1px);
			background-size: 40px 40px;
			animation: none;
		}

		#bg-layer.dots {
			background-image: radial-gradient(circle, rgba(var(--bg-color),0.65) 1.5px, transparent 1.5px);
			background-size: 22px 22px;
			animation: none;
		}

		#bg-layer.lines {
			background-image: repeating-linear-gradient(
				0deg, transparent, transparent 38px,
				rgba(var(--bg-color),0.25) 38px, rgba(var(--bg-color),0.25) 39px);
			animation: none;
		}

		#bg-layer.waves {
			background-image:
				repeating-linear-gradient(-45deg, transparent, transparent 18px, rgba(var(--bg-color),.12) 18px, rgba(var(--bg-color),.12) 19px),
				repeating-linear-gradient( 45deg, transparent, transparent 18px, rgba(var(--bg-color),.07) 18px, rgba(var(--bg-color),.07) 19px);
			animation: wavemove 3s linear infinite;
		}

		#bg-layer.nebula {
			background:
				radial-gradient(ellipse at 15% 40%, rgba(var(--bg-color),0.18) 0%, transparent 55%),
				radial-gradient(ellipse at 85% 60%, rgba(var(--bg-color),0.14) 0%, transparent 55%),
				radial-gradient(ellipse at 50% 10%, rgba(var(--bg-color),0.10) 0%, transparent 45%),
				radial-gradient(ellipse at 30% 90%, rgba(var(--bg-color),0.12) 0%, transparent 50%);
			animation: nebula 6s ease-in-out infinite;
		}

		#bg-layer.none { display: none; }

		@keyframes twinkle {
			0%, 100% { opacity: calc(var(--bg-brightness) * 0.55); }
			50%       { opacity: var(--bg-brightness); }
		}
		@keyframes wavemove {
			0%   { background-position: 0 0; }
			100% { background-position: 40px 40px; }
		}
		@keyframes nebula {
			0%, 100% { opacity: calc(var(--bg-brightness) * 0.65); }
			50%       { opacity: var(--bg-brightness); }
		}
		@keyframes spin { to { transform: rotate(360deg); } }

		/* ── TOPBAR ── */
		#topbar {
			position: fixed; top: 0; left: 0; right: 0; height: var(--top-h);
			background: var(--top); z-index: 30;
			display: flex; align-items: center; gap: 14px; padding: 0 16px;
			border-bottom: 1px solid rgba(255,255,255,.1);
			box-shadow: 0 2px 4px rgba(0,0,0,.3);
		}
		#logo { font-size: 1.3rem; font-weight: 800; color: #fff; text-shadow: 0 0 10px rgba(255,255,255,.3); white-space: nowrap; letter-spacing: -.5px; }
		#search {
			flex: 1; max-width: 480px; background: rgba(255,255,255,.07); color: var(--text);
			padding: 8px 14px; font-size: 14px; border-radius: 20px;
			border: 1px solid rgba(255,255,255,.12); outline: none; transition: border-color .2s, background .2s;
		}
		#search:focus { border-color: rgba(255,255,255,.3); background: rgba(255,255,255,.12); }
		#search::placeholder { color: rgba(255,255,255,.35); }
		#top-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
		#settings-btn, #info-btn {
			width: 36px; height: 36px; border-radius: 50%; border: none;
			background: rgba(255,255,255,.08); color: #fff; font-size: 18px;
			cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .2s;
		}
		#settings-btn:hover, #info-btn:hover { background: rgba(255,255,255,.15); }

		/* ── MAIN ── */
		#main {
			position: fixed; top: var(--top-h); left: 0; right: 0; bottom: 0;
			overflow-y: auto; background: transparent;
			scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.15) transparent; z-index: 2;
		}
		#content { padding: 20px 20px 40px; }
		.section-header { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; margin-top: 24px; }
		.section-header:first-child { margin-top: 0; }
		.section-title { font-size: 1rem; font-weight: 700; color: #fff; }
		.section-count { font-size: 12px; color: rgba(255,255,255,.4); font-weight: 400; }
		#game-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; }

		/* ── CARDS ── */
		.card {
			background: var(--card-bg);
			backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
			border-radius: 10px; cursor: pointer; overflow: hidden;
			border: 1px solid rgba(255,255,255,.13);
			transition: transform .2s, border-color .2s, background .2s, box-shadow .2s; position: relative;
		}
		.card:hover {
			transform: translateY(-3px) scale(1.02);
			border-color: rgba(255,255,255,.28);
			background: var(--card-hover);
			box-shadow: 0 6px 20px rgba(0,0,0,.35);
		}
		.card-thumb {
			width: 100%; aspect-ratio: 16/9; position: relative; overflow: hidden;
			background: rgba(255,255,255,.05);
			display: flex; align-items: center; justify-content: center;
		}
		.card-initials {
			position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
			font-size: 1.8rem; font-weight: 800; letter-spacing: -.02em;
			color: rgba(255,255,255,.22); text-shadow: 0 2px 8px rgba(0,0,0,.4); user-select: none;
		}
		.card-info { padding: 8px 10px 10px; }
		.card-name { font-size: 13px; font-weight: 600; color: rgba(255,255,255,.95); line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
		.card-fav {
			position: absolute; top: 6px; right: 6px; background: rgba(0,0,0,.5); border: none;
			cursor: pointer; width: 28px; height: 28px; border-radius: 50%; font-size: 14px;
			color: rgba(255,255,255,.5); display: flex; align-items: center; justify-content: center;
			opacity: 0; transition: opacity .15s, color .15s; z-index: 2; box-shadow: 0 2px 4px rgba(0,0,0,.3);
		}
		.card:hover .card-fav { opacity: 1; }
		.card-faon { opacity: 1 !important; color: #ffd700; }
		.card-fav:hover { color: #ffd700; }
		.card.req { border: 2px dashed rgba(255,165,0,.5); }
		.card.req .card-name { color: #ffa500; }
		body.glow-on .card:hover { box-shadow: 0 0 20px rgba(255,255,255,.22); }
		body.hover-off .card:hover { transform: none !important; }

		/* ── OVERLAY ── */
		#overlay { display: none; position: fixed; inset: 0; z-index: 50; background: #000; flex-direction: column; }
		#overlay.on { display: flex; }
		#gframe { flex: 1; width: 100%; border: none; background: #000; }
		#gload { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #000; z-index: 2; }
		#gload.hide { display: none; }
		.spin { border: 4px solid rgba(255,255,255,.2); border-top: 4px solid #fff; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin-bottom: 18px; }
		#bar-wrap { width: 260px; height: 8px; background: rgba(255,255,255,.15); border-radius: 99px; overflow: hidden; margin-top: 14px; }
		#bar { height: 100%; width: 0; background: #fff; border-radius: 99px; box-shadow: 0 0 8px rgba(255,255,255,.5); }
		#bar-lbl { margin-top: 10px; font-size: 13px; color: rgba(255,255,255,.5); }
		#fs-btn { position: fixed; right: 18px; top: 18px; padding: 8px 14px; border-radius: 8px; border: none; cursor: pointer; z-index: 60; font-weight: 700; background: #fff; color: #000; }
		#bk-btn { position: fixed; left: 18px; top: 18px; padding: 8px 14px; border-radius: 8px; border: none; cursor: pointer; z-index: 60; font-weight: 700; background: rgba(0,0,0,.55); color: #fff; }

		/* ── GAME MODAL ── */
		.modal { display: none; position: fixed; z-index: 55; inset: 0; background: rgba(0,0,0,.75); backdrop-filter: blur(6px); }
		.modal.on { display: flex; align-items: center; justify-content: center; }
		.modal-box { background: rgba(13,17,23,0.92); backdrop-filter: blur(12px); padding: 28px; border-radius: 14px; max-width: 460px; width: 90%; color: var(--text); border: 1px solid rgba(255,255,255,.12); max-height: 80vh; overflow-y: auto; box-shadow: 0 10px 40px rgba(0,0,0,.5); }
		.modal-thumb { width: 100%; aspect-ratio: 16/9; border-radius: 8px; overflow: hidden; margin-bottom: 18px; position: relative; background: rgba(255,255,255,.05); display: flex; align-items: center; justify-content: center; }
		.modal-thumb-title { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; font-weight: 800; color: rgba(255,255,255,.22); letter-spacing: -.02em; }
		.mtrow { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
		.mtrow h2 { flex: 1; font-size: 1.2rem; color: #fff; }
		.mfav { font-size: 22px; background: none; border: none; cursor: pointer; color: rgba(255,255,255,.3); transition: color .2s; padding: 4px; }
		.mfav:hover, .mfaon { color: #ffd700; }
		.mstat { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,.1); font-size: 14px; }
		.mstat:last-of-type { border: none; }
		.mstat b { color: rgba(255,255,255,.5); font-weight: 600; }
		.mbtns { display: flex; gap: 10px; margin-top: 18px; justify-content: center; }
		.mbtns button { padding: 10px 22px; border: none; border-radius: 8px; cursor: pointer; font-weight: 700; font-size: 14px; }
		.mbplay { background: #fff; color: #000; }
		.mbplay:hover { filter: brightness(0.9); }
		.mbclose { background: rgba(255,255,255,.1); color: var(--text); border: 1px solid rgba(255,255,255,.2); }
		.mbclose:hover { background: rgba(255,255,255,.18); }

		/* ── SETTINGS DRAWER ── */
		#settings-drawer { position: fixed; right: -420px; top: 0; bottom: 0; width: 400px; background: rgba(10,14,20,0.97); backdrop-filter: blur(10px); z-index: 100; transition: right .3s; overflow: hidden; border-left: 1px solid rgba(255,255,255,.1); box-shadow: -2px 0 30px rgba(0,0,0,.5); display: flex; flex-direction: column; }
		#settings-drawer.open { right: 0; }
		.settings-header { padding: 18px 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,.1); flex-shrink: 0; }
		.settings-header h2 { color: #fff; font-size: 1.2rem; }
		.settings-close-btn { background: none; border: none; color: rgba(255,255,255,.4); font-size: 22px; cursor: pointer; padding: 4px; transition: color .2s; }
		.settings-close-btn:hover { color: #fff; }
		.settings-tabs { display: flex; border-bottom: 1px solid rgba(255,255,255,.1); flex-shrink: 0; }
		.settings-tab { flex: 1; padding: 12px 8px; border: none; background: rgba(255,255,255,.04); color: rgba(255,255,255,.5); cursor: pointer; font-size: 11px; font-weight: 600; transition: all .2s; border-bottom: 2px solid transparent; }
		.settings-tab:hover { background: rgba(255,255,255,.09); }
		.settings-tab.active { background: rgba(255,255,255,.07); color: #fff; border-bottom-color: #fff; }
		.settings-content { flex: 1; overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.1) transparent; }
		.settings-panel { display: none; padding: 16px 18px; }
		.settings-panel.active { display: block; }
		.settings-group { margin-bottom: 22px; }
		.settings-group-title { display: block; color: rgba(255,255,255,.4); font-weight: 700; font-size: 10px; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 12px; }
		.settings-option { margin-bottom: 14px; }
		.settings-option label { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; color: rgba(255,255,255,.8); }
		.settings-toggle { width: 40px; height: 22px; background: rgba(255,255,255,.1); border: none; border-radius: 12px; cursor: pointer; position: relative; transition: background .2s; margin-left: auto; flex-shrink: 0; }
		.settings-toggle::after { content: ''; position: absolute; width: 18px; height: 18px; background: #fff; border-radius: 50%; top: 2px; left: 2px; transition: left .2s; }
		.settings-toggle.active { background: rgba(255,255,255,.3); }
		.settings-toggle.active::after { left: 20px; }
		.settings-buttons { display: flex; flex-direction: column; gap: 8px; }
		.settings-btn { padding: 10px; border-radius: 8px; background: rgba(255,255,255,.08); color: #fff; cursor: pointer; font-weight: 600; font-size: 13px; text-align: center; transition: background .2s; border: 1px solid rgba(255,255,255,.15); }
		.settings-btn:hover { background: rgba(255,255,255,.15); }
		.settings-description { font-size: 12px; color: rgba(255,255,255,.3); margin-top: 6px; line-height: 1.4; }

		.slider-row { display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: rgba(255,255,255,.6); margin-bottom: 4px; }
		.slider-val { color: rgba(255,255,255,.85); font-weight: 600; }
		.range-slider { width: 100%; height: 5px; border-radius: 3px; background: rgba(255,255,255,.14); outline: none; -webkit-appearance: none; appearance: none; margin: 10px 0 4px; cursor: pointer; }
		.range-slider::-webkit-slider-thumb { -webkit-appearance: none; width: 16px; height: 16px; border-radius: 50%; background: #fff; cursor: pointer; box-shadow: 0 0 6px rgba(255,255,255,.4); }
		.range-slider::-moz-range-thumb { width: 16px; height: 16px; border-radius: 50%; background: #fff; cursor: pointer; border: none; }

		.bg-grid-options { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 6px; }
		.bg-option { padding: 10px; border: 2px solid rgba(255,255,255,.12); border-radius: 8px; background: rgba(255,255,255,.04); color: #fff; cursor: pointer; font-size: 12px; font-weight: 600; text-align: center; transition: all .2s; }
		.bg-option:hover { border-color: rgba(255,255,255,.28); background: rgba(255,255,255,.09); }
		.bg-option.active { border-color: #fff; background: rgba(255,255,255,.14); }

		.color-swatches { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
		.color-swatch { width: 28px; height: 28px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: border-color .2s, transform .15s; flex-shrink: 0; }
		.color-swatch:hover { transform: scale(1.15); }
		.color-swatch.active { border-color: #fff; box-shadow: 0 0 0 2px rgba(255,255,255,.4); }
		.color-picker-row { display: flex; align-items: center; gap: 10px; margin-top: 4px; }
		.color-picker-row label { font-size: 13px; color: rgba(255,255,255,.6); }
		#custom-color { width: 36px; height: 30px; border: 1px solid rgba(255,255,255,.2); border-radius: 6px; cursor: pointer; padding: 2px; background: rgba(255,255,255,.05); }

		/* ── INFO MODAL ── */
		#info-modal { display: none; position: fixed; z-index: 105; inset: 0; background: rgba(0,0,0,.75); backdrop-filter: blur(6px); }
		#info-modal.on { display: flex; align-items: center; justify-content: center; }
		.info-box { background: rgba(13,17,23,0.95); backdrop-filter: blur(12px); padding: 28px; border-radius: 14px; max-width: 500px; width: 90%; color: #fff; border: 1px solid rgba(255,255,255,.12); max-height: 80vh; overflow-y: auto; box-shadow: 0 10px 40px rgba(0,0,0,.5); }
		.info-box h2 { margin-bottom: 16px; font-size: 1.3rem; }
		.info-textarea { width: 100%; height: 300px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 8px; color: #fff; padding: 12px; font-family: 'Courier New', monospace; font-size: 13px; resize: none; margin-bottom: 16px; }
		.info-textarea::placeholder { color: rgba(255,255,255,.3); }
		.info-textarea:focus { outline: none; border-color: rgba(255,255,255,.3); background: rgba(255,255,255,.08); }
		.info-footer { display: flex; gap: 10px; justify-content: center; }
		.info-btn { padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all .2s; }
		.info-btn-primary { background: rgba(255,255,255,.2); color: #fff; border: 1px solid rgba(255,255,255,.3); }
		.info-btn-primary:hover { background: rgba(255,255,255,.3); }
		.info-btn-secondary { background: rgba(255,255,255,.05); color: rgba(255,255,255,.8); border: 1px solid rgba(255,255,255,.1); }
		.info-btn-secondary:hover { background: rgba(255,255,255,.1); }
	</style>
</head>

<body>
	<canvas id="bg-canvas"></canvas>
	<div id="bg-layer" class="stars"></div>

	<div id="topbar">
		<div id="logo">MathLine</div>
		<input id="search" type="text" placeholder="Search games..." />
		<div id="top-right">
			<button id="info-btn">&#9432;</button>
			<button id="settings-btn">&#9881;</button>
		</div>
	</div>

	<div id="main">
		<div id="content">
			<div class="section-header">
				<h1 class="section-title">Games</h1>
				<span class="section-count" id="game-count">0 games</span>
			</div>
			<div id="game-list"></div>
		</div>
	</div>

	<div id="overlay">
		<div id="gload">
			<div class="spin"></div>
			<div id="bar-lbl">Loading...</div>
			<div id="bar-wrap"><div id="bar"></div></div>
		</div>
		<iframe id="gframe"></iframe>
		<button id="fs-btn">Fullscreen</button>
		<button id="bk-btn">&#8592; Back</button>
	</div>

	<div class="modal" id="game-modal">
		<div class="modal-box">
			<div class="modal-thumb">
				<div class="modal-thumb-title" id="modal-thumb-title">A</div>
			</div>
			<div class="mtrow">
				<h2 id="modal-game-name">Game Name</h2>
				<button class="mfav" id="modal-fav">&#9734;</button>
			</div>
			<div id="game-stats"></div>
			<div class="mbtns">
				<button class="mbplay" id="play-game-btn">Play Now</button>
				<button class="mbclose" id="close-game-modal">Close</button>
			</div>
		</div>
	</div>

	<div id="settings-drawer">
		<div class="settings-header">
			<h2>Settings</h2>
			<button class="settings-close-btn" id="settings-close-btn">&#10005;</button>
		</div>
		<div class="settings-tabs">
			<button class="settings-tab active" data-tab="appearance">Appearance</button>
			<button class="settings-tab" data-tab="background">Background</button>
			<button class="settings-tab" data-tab="gameplay">Gameplay</button>
			<button class="settings-tab" data-tab="advanced">Advanced</button>
		</div>
		<div class="settings-content">

			<div class="settings-panel active" data-panel="appearance">
				<div class="settings-group">
					<span class="settings-group-title">Visual Effects</span>
					<div class="settings-option">
						<label><span>Card Animations</span><button class="settings-toggle active" id="animation-toggle"></button></label>
						<div class="settings-description">Enable smooth card hover transitions</div>
					</div>
					<div class="settings-option">
						<label><span>Glow Effects</span><button class="settings-toggle" id="glow-toggle"></button></label>
						<div class="settings-description">Add glow effect to cards on hover</div>
					</div>
					<div class="settings-option">
						<label><span>Text Shadows</span><button class="settings-toggle active" id="shadow-toggle"></button></label>
						<div class="settings-description">Add shadows to text elements</div>
					</div>
				</div>
			</div>

			<div class="settings-panel" data-panel="background">
