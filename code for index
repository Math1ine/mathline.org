			return gameList.sort((a, b) => {
				const aIsFav = favorites.has(a.n);
				const bIsFav = favorites.has(b.n);
				if (aIsFav && !bIsFav) return -1;
				if (!aIsFav && bIsFav) return 1;
				return 0;
			});
		}

		function renderGames(gameList = allGames, searchQuery = '') {
			const sortedGames = getSortedGames(gameList);
