	// ── RENDER ──
	function renderGames() {
		const q = currentSearchQuery.toLowerCase();
		const filtered = GAMES.filter(g => g.n.toLowerCase().includes(q));
		const sorted = [...filtered].sort((a,b) => {
			const af = favorites.has(a.n), bf = favorites.has(b.n);
			return af === bf ? 0 : af ? -1 : 1;
		});
		const container = document.getElementById('game-list');
		container.innerHTML = '';

		if (currentSearchQuery.trim()) {
			const r = document.createElement('div');
			r.className = 'card req';
			r.innerHTML = `<div class="card-thumb"><div class="card-initials">?</div></div><div class="card-info"><div class="card-name">Request a Game</div></div>`;
			r.onclick = () => alert(`Game request for "${currentSearchQuery}" noted!`);
			container.appendChild(r);
		}

		sorted.forEach(game => {
			const isFav = favorites.has(game.n);
			const card = document.createElement('div');
			card.className = 'card';
			card.innerHTML = `
				<div class="card-thumb">
					<div class="card-initials">${game.n.charAt(0)}</div>
					<button class="card-fav ${isFav ? 'card-faon' : ''}">&#9733;</button>
				</div>
				<div class="card-info"><div class="card-name">${game.n}</div></div>`;
			card.onclick = () => showGameModal(game);
			card.querySelector('.card-fav').onclick = e => { e.stopPropagation(); toggleFav(game.n); };
			container.appendChild(card);
		});
		document.getElementById('game-count').textContent = `${sorted.length} games`;
	}

	function showGameModal(game) {
		document.getElementById('modal-thumb-title').textContent = game.n.charAt(0);
		document.getElementById('modal-game-name').textContent = game.n;
		document.getElementById('game-stats').innerHTML =
			`<div class="mstat"><b>Category:</b> <span>${game.c}</span></div>`;
		const fb = document.getElementById('modal-fav');
		fb.innerHTML = favorites.has(game.n) ? '&#9733;' : '&#9734;';
		fb.classList.toggle('mfaon', favorites.has(game.n));
		fb.onclick = () => { toggleFav(game.n); showGameModal(game); };
		document.getElementById('play-game-btn').onclick = () => launchGame(game.u);
		document.getElementById('close-game-modal').onclick = closeModal;
		document.getElementById('game-modal').classList.add('on');
	}

	function closeModal() { document.getElementById('game-modal').classList.remove('on'); }

	function launchGame(url) {
		closeModal();
		if (settings.autoload) {
			document.getElementById('overlay').classList.add('on');
			document.getElementById('gload').classList.remove('hide');
			document.getElementById('gframe').src = url;
			setTimeout(() => document.getElementById('gload').classList.add('hide'), 2500);
		}
	}

	function toggleFav(name) {
		favorites.has(name) ? favorites.delete(name) : favorites.add(name);
		localStorage.setItem('favorites', JSON.stringify([...favorites]));
		renderGames();
	}

