			container.innerHTML = '';

			if (searchQuery.trim().length > 0) {
				const reqCard = document.createElement('div');
				reqCard.className = 'card req';
				reqCard.innerHTML = `
					<div class="card-thumb">
						<div class="card-thumb-grad"></div>
						<div class="card-initials">❓</div>
					</div>
					<div class="card-info">
