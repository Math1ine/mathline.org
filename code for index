					</div>
				`;
				reqCard.onclick = () => {
					alert(`Game request for "${searchQuery}" has been noted!`);
				};
				container.appendChild(reqCard);
			}

			sortedGames.forEach(game => {
				const card = document.createElement('div');
				card.className = 'card';
				const isFav = favorites.has(game.n);
				
				card.innerHTML = `
					<div class="card-thumb">
						<div class="card-thumb-grad"></div>
						<div class="card-initials">${game.n.charAt(0)}</div>
						<button class="card-fav ${isFav ? 'card-faon' : ''}">★</button>
					</div>
					<div class="card-info">
						<div class="card-name">${game.n}</div>
					</div>
				`;

				card.onclick = () => showGameModal(game);
				const favBtn = card.querySelector('.card-fav');
				favBtn.onclick = (e) => {
					e.stopPropagation();
					toggleFavorite(game.n, favBtn);
				};

				container.appendChild(card);
			});

			document.getElementById('game-count').textContent = `${sortedGames.length} games`;
		}

		function showGameModal(game) {
			const modal = document.getElementById('game-modal');
			document.getElementById('modal-title').textContent = game.n;
			document.getElementById('modal-icon').textContent = game.n.charAt(0);
			
			const isFav = favorites.has(game.n);
			const favBtn = document.getElementById('modal-fav');
			favBtn.textContent = isFav ? '★' : '☆';
			if (isFav) {
				favBtn.classList.add('mfaon');
			} else {
				favBtn.classList.remove('mfaon');
			}

			const stats = `
				<div class="mstat"><span>Category:</span><b>${game.c}</b></div>
			`;
			document.getElementById('modal-stats').innerHTML = stats;

			const playBtn = document.getElementById('modal-play');
			playBtn.onclick = () => playGame(game);

			const modalFav = document.getElementById('modal-fav');
			modalFav.onclick = (e) => {
				e.stopPropagation();
				toggleFavorite(game.n, modalFav);
			};

			modal.classList.add('on');
		}

		function closeGameModal() {
			document.getElementById('game-modal').classList.remove('on');
		}

		function playGame(game) {
			closeGameModal();
			if (settings.autoload) {
				const overlay = document.getElementById('overlay');
				overlay.classList.add('on');
				document.getElementById('gframe').src = game.u;

				setTimeout(() => {
					document.getElementById('gload').classList.add('hide');
				}, 2000);
			}
		}

		function toggleFavorite(gameName, button) {
			if (favorites.has(gameName)) {
				favorites.delete(gameName);
				button.classList.remove('card-faon', 'mfaon');
				button.textContent = '☆';
			} else {
				favorites.add(gameName);
				button.classList.add('card-faon', 'mfaon');
				button.textContent = '★';
			}
			localStorage.setItem('favorites', JSON.stringify([...favorites]));
			renderGames();
		}

		// Settings Drawer
		const settingsBtn = document.getElementById('settings-btn');
		const settingsDrawer = document.getElementById('settings-drawer');
		const settingsCloseBtn = document.querySelector('.settings-close-btn');

		settingsBtn.onclick = () => {
			settingsDrawer.classList.add('open');
		};

		settingsCloseBtn.onclick = () => {
			settingsDrawer.classList.remove('open');
		};

		// Settings Tabs
		const settingsTabs = document.querySelectorAll('.settings-tab');
		const settingsPanels = document.querySelectorAll('.settings-panel');

		settingsTabs.forEach(tab => {
			tab.onclick = () => {
				settingsTabs.forEach(t => t.classList.remove('active'));
				settingsPanels.forEach(p => p.classList.remove('active'));
				tab.classList.add('active');
				document.querySelector(`[data-panel="${tab.dataset.tab}"]`).classList.add('active');
			};
		});

		// Animation Toggle
		document.getElementById('animation-toggle').onclick = function() {
			this.classList.toggle('active');
			settings.animations = this.classList.contains('active');
			if (settings.animations) {
				document.body.classList.remove('hover-off');
			} else {
				document.body.classList.add('hover-off');
			}
			localStorage.setItem('animations', settings.animations);
		};

		// Glow Toggle
		document.getElementById('glow-toggle').onclick = function() {
			this.classList.toggle('active');
			settings.glow = this.classList.contains('active');
			if (settings.glow) {
				document.body.classList.add('glow-on');
			} else {
				document.body.classList.remove('glow-on');
			}
			localStorage.setItem('glow', settings.glow);
		};

		// Shadow Toggle
		document.getElementById('shadow-toggle').onclick = function() {
			this.classList.toggle('active');
			settings.shadow = this.classList.contains('active');
			localStorage.setItem('shadow', settings.shadow);
		};

		// Autoload Toggle
		document.getElementById('autoload-toggle').onclick = function() {
			this.classList.toggle('active');
			settings.autoload = this.classList.contains('active');
			localStorage.setItem('autoload', settings.autoload);
		};

		// Sound Toggle
		document.getElementById('sound-toggle').onclick = function() {
			this.classList.toggle('active');
			settings.sound = this.classList.contains('active');
			localStorage.setItem('sound', settings.sound);
		};

		// Playcount Toggle
		document.getElementById('playcount-toggle').onclick = function() {
			this.classList.toggle('active');
			settings.playcount = this.classList.contains('active');
			localStorage.setItem('playcount', settings.playcount);
		};

		// Hover Effect Toggle
		document.getElementById('hover-effect').onclick = function() {
			this.classList.toggle('active');
			settings.hoverEffect = this.classList.contains('active');
			if (!settings.hoverEffect) {
				document.body.classList.add('hover-off');
			} else {
				document.body.classList.remove('hover-off');
			}
			localStorage.setItem('hoverEffect', settings.hoverEffect);
		};

		// Smooth Scroll Toggle
		document.getElementById('smooth-scroll').onclick = function() {
			this.classList.toggle('active');
			settings.smoothScroll = this.classList.contains('active');
			if (settings.smoothScroll) {
				document.documentElement.style.scrollBehavior = 'smooth';
			} else {
				document.documentElement.style.scrollBehavior = 'auto';
			}
			localStorage.setItem('smoothScroll', settings.smoothScroll);
		};

		// Background Options
		const bgOptions = document.querySelectorAll('.bg-option');
		bgOptions.forEach(opt => {
			opt.onclick = () => {
				bgOptions.forEach(o => o.classList.remove('active'));
				opt.classList.add('active');
				const bgType = opt.dataset.bg;
				document.body.classList.forEach(cls => {
					if (cls.startsWith('bg-')) {
						document.body.classList.remove(cls);
					}
				});
				if (bgType !== 'none') {
					document.body.classList.add('bg-' + bgType);
				}
				settings.bgEffect = bgType;
				localStorage.setItem('bgEffect', bgType);
			};
		});

		// Background Speed
		document.getElementById('bg-speed').oninput = function() {
			settings.bgSpeed = this.value;
			localStorage.setItem('bgSpeed', this.value);
		};

		// Grid Size
		document.getElementById('grid-size').onchange = function() {
			settings.gridSize = this.value;
			updateGridSize();
			localStorage.setItem('gridSize', this.value);
		};

		// Clear Favorites
		document.getElementById('clear-favorites').onclick = () => {
			if (confirm('Clear all favorites?')) {
				favorites.clear();
				localStorage.setItem('favorites', '[]');
				renderGames();
				alert('Favorites cleared!');
			}
		};

		// Clear Cache
		document.getElementById('clear-cache').onclick = () => {
			if (confirm('Clear all cached data?')) {
				alert('Cache cleared!');
			}
		};

		// Reset Settings
		document.getElementById('reset-settings').onclick = () => {
			if (confirm('Reset all settings to defaults?')) {
				localStorage.clear();
				location.reload();
			}
		};

		// Info Modal
		const infoBtn = document.getElementById('info-btn');
		const infoModal = document.getElementById('info-modal');
		const saveInfoBtn = document.getElementById('save-info');
		const closeInfoBtn = document.getElementById('close-info');
		const infoTextarea = document.getElementById('info-textarea');

		infoBtn.onclick = () => {
			infoTextarea.value = localStorage.getItem('userInfo') || '';
			infoModal.classList.add('on');
		};

		saveInfoBtn.onclick = () => {
			localStorage.setItem('userInfo', infoTextarea.value);
			alert('Information saved!');
		};

		closeInfoBtn.onclick = () => {
			infoModal.classList.remove('on');
		};

		// Close modal when clicking close button
		document.querySelector('.mbclose').onclick = closeGameModal;

		// Search functionality
		let currentSearchQuery = '';
		document.getElementById('search').addEventListener('input', (e) => {
			currentSearchQuery = e.target.value;
			const query = currentSearchQuery.toLowerCase();
			const filtered = allGames.filter(g => g.n.toLowerCase().includes(query));
			renderGames(filtered, currentSearchQuery);
		});

		// Exit fullscreen
		document.getElementById('fs-btn').onclick = () => {
			document.getElementById('overlay').classList.remove('on');
			document.getElementById('gframe').src = '';
			document.getElementById('gload').classList.remove('hide');
		};

		// Back button
		document.getElementById('bk-btn').onclick = () => {
			document.getElementById('overlay').classList.remove('on');
			document.getElementById('gframe').src = '';
			document.getElementById('gload').classList.remove('hide');
		};

		// Initialize
		loadSettings();
		renderGames();
		if (settings.smoothScroll) {
			document.documentElement.style.scrollBehavior = 'smooth';
		}
	</script>
</body>

</html>
