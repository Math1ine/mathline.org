	// ── RAIN CANVAS ──
	const canvas = document.getElementById('bg-canvas');
	const ctx = canvas.getContext('2d');
	let drops = [];
	let rainRAF = null;
	let rainRGB = [255,255,255];

	function resizeCanvas() {
		canvas.width  = window.innerWidth;
		canvas.height = window.innerHeight;
	}

	function initDrops() {
		drops = [];
		const count = Math.floor(canvas.width / 12);
		for (let i = 0; i < count; i++) {
			drops.push({
				x:   Math.random() * canvas.width,
				y:   Math.random() * canvas.height,
				len: Math.random() * 16 + 10,
				spd: Math.random() * 5 + 5,
				op:  Math.random() * 0.55 + 0.25,
				w:   Math.random() < 0.4 ? 1.5 : 1
			});
		}
	}

	function animRain() {
		ctx.clearRect(0, 0, canvas.width, canvas.height);
		const br = settings.bgBrightness / 100;
		const [r,g,b] = rainRGB;
		for (const d of drops) {
			ctx.beginPath();
			ctx.moveTo(d.x, d.y);
			ctx.lineTo(d.x - d.len * 0.15, d.y + d.len);
			ctx.strokeStyle = `rgba(${r},${g},${b},${d.op * br})`;
			ctx.lineWidth = d.w;
			ctx.stroke();
			d.y += d.spd;
			if (d.y - d.len > canvas.height) {
				d.y = -d.len;
				d.x = Math.random() * canvas.width;
				d.op = Math.random() * 0.55 + 0.25;
			}
		}
		rainRAF = requestAnimationFrame(animRain);
	}

	function startRain() {
		resizeCanvas(); initDrops();
		canvas.style.display = 'block';
		if (rainRAF) cancelAnimationFrame(rainRAF);
		animRain();
	}

	function stopRain() {
		if (rainRAF) { cancelAnimationFrame(rainRAF); rainRAF = null; }
		canvas.style.display = 'none';
		ctx.clearRect(0, 0, canvas.width, canvas.height);
	}

	window.addEventListener('resize', () => {
		if (settings.bgEffect === 'rain') { resizeCanvas(); initDrops(); }
	});

	// ── COLOR HELPERS ──
	function hexToRgb(hex) {
		return [
			parseInt(hex.slice(1,3),16),
			parseInt(hex.slice(3,5),16),
			parseInt(hex.slice(5,7),16)
		].join(',');
	}

	function rgbToHex(rgb) {
		return '#' + rgb.split(',').map(v => parseInt(v).toString(16).padStart(2,'0')).join('');
	}

	function applyColor(rgb) {
		settings.bgColor = rgb;
		localStorage.setItem('bgColor', rgb);
		document.documentElement.style.setProperty('--bg-color', rgb);
		rainRGB = rgb.split(',').map(Number);
		try { document.getElementById('custom-color').value = rgbToHex(rgb); } catch(e){}
		document.querySelectorAll('.color-swatch').forEach(s =>
			s.classList.toggle('active', s.dataset.rgb === rgb));
	}

	// ── BG EFFECT ──
	function applyEffect(effect) {
		settings.bgEffect = effect;
		localStorage.setItem('bgEffect', effect);
		const layer = document.getElementById('bg-layer');

		stopRain();
		if (effect === 'rain') {
			layer.className = 'none';
			startRain();
		} else {
			layer.className = effect; // matches CSS #bg-layer.stars etc.
		}

		document.querySelectorAll('.bg-option').forEach(o =>
			o.classList.toggle('active', o.dataset.bg === effect));
	}

	// ── BRIGHTNESS ──
	function applyBrightness(val) {
		settings.bgBrightness = parseInt(val);
		localStorage.setItem('bgBrightness', val);
		document.documentElement.style.setProperty('--bg-brightness', val / 100);
		document.getElementById('brightness-value').textContent = val + '%';
	}

	// ── INIT ──
	function loadSettings() {
		if (!settings.animations || !settings.hoverEffect) document.body.classList.add('hover-off');
		if (settings.glow) document.body.classList.add('glow-on');
		if (settings.smoothScroll) document.documentElement.style.scrollBehavior = 'smooth';

		document.getElementById('grid-size').value = settings.gridSize;
		updateGridSize();

		document.getElementById('brightness-slider').value = settings.bgBrightness;
		applyBrightness(settings.bgBrightness);
		applyColor(settings.bgColor);
		applyEffect(settings.bgEffect);

		syncToggle('animation-toggle', settings.animations);
		syncToggle('glow-toggle',      settings.glow);
		syncToggle('shadow-toggle',    settings.shadow);
		syncToggle('autoload-toggle',  settings.autoload);
		syncToggle('playcount-toggle', settings.playcount);
		syncToggle('hover-effect',     settings.hoverEffect);
		syncToggle('smooth-scroll',    settings.smoothScroll);
	}

	function syncToggle(id, val) {
		document.getElementById(id).classList.toggle('active', !!val);
